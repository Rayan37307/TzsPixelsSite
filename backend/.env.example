# ---- Core ----
NODE_ENV=production
PORT=5000
# Postgres connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
# Comma-separated allowed browser origins for the dashboard (CORS). Leave unset to allow all (dev only).
FRONTEND_ORIGIN=https://dashboard.yourdomain.com

# ---- AI (chatbot) ----
GEMINI_API_KEY=

# ---- Facebook Messenger DM automation ----
FB_PAGE_ID=
FB_ACCESS_TOKEN=
# Shared webhook verification token (set the same value in the Meta app webhook config)
FB_VERIFY_TOKEN=

# ---- Instagram DM automation (Instagram Login / graph.instagram.com) ----
# IG account's own user_id (GET https://graph.instagram.com/v21.0/me?fields=user_id)
IG_BUSINESS_ACCOUNT_ID=
# Instagram user access token (starts with "IGA..."), NOT the FB Page token
IG_ACCESS_TOKEN=

# ---- Fraud detection: BDCourier courier-check ----
BDCOURIER_API_KEY=

# ---- Storefront integration ----
# Which CMS drives order/abandoned scans: 'shopify' or 'woocommerce'
CMS=shopify
SHOPIFY_SHOP=
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
# JSON array of WooCommerce store configs (if CMS=woocommerce)
WOOCOMMERCE_STORES=
