# docker-compose variables (copy to .env at repo root for `docker compose up`)

# Postgres (used by the db service and injected into backend DATABASE_URL)
POSTGRES_USER=tzs
POSTGRES_PASSWORD=change_me
POSTGRES_DB=tzs

# Public URL the browser uses to reach the backend API (baked into the frontend at build)
VITE_API_BASE_URL=http://localhost:5000/api

# NOTE: backend app secrets (FB/IG/Gemini/BDCourier/Shopify) live in backend/.env
# (see backend/.env.example). docker-compose loads them via env_file.
